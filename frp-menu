#!/bin/bash

# FRP Bypass Tool for Linux - At your own risk 
# Requirements: android-tools-adb

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Log file
LOG_FILE="frp_bypass.log"

# Log function
log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"
}

# Clean up ADB server on script termination
trap 'adb kill-server &>/dev/null; echo -e "${RED}Script terminated. ADB server stopped.${NC}"; log "Script terminated."; exit 1' SIGINT SIGTERM

# Check device connection with retry logic
check_device_connection() {
  local retries=3
  local attempt=1
  while [ $attempt -le $retries ]; do
    adb start-server &>/dev/null || { echo -e "${RED}ADB server failed to start (attempt $attempt/$retries).${NC}"; log "ADB start failed."; return 1; }
    if adb devices | grep -q "device$"; then
      log "Device connected."
      return 0
    fi
    echo -e "${RED}No device connected (attempt $attempt/$retries). Checking again...${NC}"
    adb kill-server &>/dev/null
    sleep 2
    ((attempt++))
  done
  echo -e "${RED}No device connected after $retries attempts. Please reconnect using the connection menu.${NC}"
  log "Connection failed after retries."
  return 1
}

# Ensure android-tools is installed
install_android_tools() {
  echo -e "${GREEN}Checking for android-tools...${NC}"
  if command -v adb &>/dev/null; then
    echo -e "${GREEN}android-tools is already installed.${NC}"
    log "android-tools installed."
    return
  fi
  if [ -f /etc/debian_version ]; then
    echo -e "${GREEN}Debian/Ubuntu detected. Installing...${NC}"
    sudo apt update || { echo -e "${RED}Failed to update package lists.${NC}"; log "APT update failed."; exit 1; }
    sudo apt install -y android-tools-adb || { echo -e "${RED}Failed to install android-tools.${NC}"; log "Install failed."; exit 1; }
  elif [ -f /etc/arch-release ]; then
    echo -e "${GREEN}Arch Linux detected. Installing...${NC}"
    sudo pacman -Sy --noconfirm android-tools || { echo -e "${RED}Failed to install android-tools.${NC}"; log "Install failed."; exit 1; }
  else
    echo -e "${RED}Unsupported system. Please install android-tools manually.${NC}"
    log "Unsupported system."
    exit 1
  fi
  if ! command -v adb &>/dev/null; then
    echo -e "${RED}Failed to install android-tools. Please install manually.${NC}"
    log "Install verification failed."
    exit 1
  fi
  log "android-tools installed successfully."
}

# ADB USB connection
connect_usb() {
  adb kill-server
  adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; log "ADB server start failed."; exit 1; }
  echo -e "${GREEN}Looking for USB devices...${NC}"
  for i in {1..3}; do
    adb devices
    if adb devices | grep -q "unauthorized"; then
      echo -e "${RED}Device unauthorized. Please accept the ADB connection on your device (attempt $i/3).${NC}"
      sleep 5
      adb kill-server
      adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; log "ADB restart failed."; exit 1; }
    elif adb devices | grep -q "device$"; then
      echo -e "${GREEN}Connected via USB.${NC}"
      log "USB connection successful."
      return 0
    else
      echo -e "${RED}No device found via USB (attempt $i/3).${NC}"
      sleep 5
      adb kill-server
      adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; log "ADB restart failed."; exit 1; }
    fi
  done
  echo -e "${RED}Failed to connect via USB after 3 attempts.${NC}"
  log "USB connection failed."
  return 1
}

