    esac
  else
    echo -e "${RED}Failed to enable processing boost management.${NC}"
    return 1
  fi
  read -r -p "Press Enter to return..."
}

optimize_app_performance() {
  check_device_connection || return 1
  echo -e "${RED}Warning: This could damage your device. Use at your own risk.${NC}"
  read -r -p "Do you want to proceed? (y/n): " choice
  case "$choice" in
    y|Y ) ;;
    n|N ) return 0 ;;
    * ) echo -e "${YELLOW}Invalid choice. Returning to menu.${NC}"; return 1 ;;
  esac
  echo -e "${GREEN}Optimizing application performance...${NC}"
  echo -e "${YELLOW}This may take a while for devices with many apps.${NC}"

  # Detect Android version
  local android_version_str=$(adb shell getprop ro.build.version.release | tr -d '\r')
  local android_version_major=${android_version_str%%.*}
  if ! [[ "$android_version_major" =~ ^[0-9]+$ ]]; then
    android_version_major=0  # Default to unknown/older if parsing fails
    echo -e "${YELLOW}Could not detect Android version; assuming compatibility mode.${NC}"
  fi
  echo -e "${GREEN}Detected Android version: $android_version_str${NC}"

  local success_count=0
  local total=0  # We'll increment total for each attempted step

  # Non-root optimizations (version-aware)
  ((total++))
  if adb shell cmd package bg-dexopt-job &>/dev/null; then
    ((success_count++))
    echo -e "${GREEN}Background dexopt job completed.${NC}"
  else
    echo -e "${YELLOW}Failed to run background dexopt (may not be supported on Android <8).${NC}"
  fi

  # App compilation: Choose mode based on version
  ((total++))
  local compile_mode="speed-profile"
  local compile_desc="speed-profile"
  if [[ $android_version_major -ge 15 ]]; then
    compile_mode="quicken"
    compile_desc="quicken (Android 15+ for faster startup)"
  elif [[ $android_version_major -ge 10 ]]; then
    compile_mode="speed-profile"
    compile_desc="speed-profile (Android 10+ with profile-guided optimization)"
  elif [[ $android_version_major -ge 7 ]]; then
    compile_mode="speed"
    compile_desc="speed (Android 7-9 for full AOT compilation)"
  else
    compile_mode="verify"
    compile_desc="verify (Older Android versions for basic verification)"
  fi

  if adb shell cmd package compile -m "$compile_mode" -f -a &>/dev/null; then
    ((success_count++))
    echo -e "${GREEN}Apps optimized with $compile_desc.${NC}"
  else
    echo -e "${YELLOW}Failed to optimize apps with $compile_desc.${NC}"
    # Fallback to speed or verify
    ((total++))
    if adb shell cmd package compile -m speed -f -a &>/dev/null; then
      ((success_count++))
      echo -e "${GREEN}Fallback: Apps optimized with speed mode.${NC}"
    elif adb shell cmd package compile -m verify -f -a &>/dev/null; then
      ((success_count++))
      echo -e "${GREEN}Fallback: Apps verified for compatibility (older versions).${NC}"
    else
      echo -e "${YELLOW}Failed all compilation fallbacks.${NC}"
    fi
  fi

  ((total++))
  if adb shell pm trim-caches 999G &>/dev/null; then
    ((success_count++))
    echo -e "${GREEN}App caches trimmed for better performance.${NC}"
  else
    echo -e "${YELLOW}Failed to trim app caches (may not be supported on older versions).${NC}"
  fi

  # Additional non-root optimizations (UI and app tweaks for perceived performance)
  ((total++))
  if adb shell settings put global window_animation_scale 0.5 &>/dev/null; then
    ((success_count++))
    echo -e "${GREEN}Reduced window animation scale for snappier UI.${NC}"
  else
    echo -e "${YELLOW}Failed to adjust window animation scale.${NC}"
  fi

  ((total++))
  if adb shell settings put global transition_animation_scale 0.5 &>/dev/null; then
    ((success_count++))
    echo -e "${GREEN}Reduced transition animation scale for faster app switching.${NC}"
  else
    echo -e "${YELLOW}Failed to adjust transition animation scale.${NC}"
  fi

  ((total++))
  if adb shell settings put global animator_duration_scale 0.5 &>/dev/null; then
    ((success_count++))
    echo -e "${GREEN}Reduced animator duration scale for quicker responses.${NC}"
  else
    echo -e "${YELLOW}Failed to adjust animator duration scale.${NC}"
  fi

  ((total++))
  if adb shell settings put global app_standby_enabled 0 &>/dev/null; then
    ((success_count++))
    echo -e "${GREEN}Disabled app standby for unrestricted background apps (may impact battery).${NC}"
  else
    echo -e "${YELLOW}Failed to disable app standby (may not be supported).${NC}"
  fi

  ((total++))
  if adb shell settings put system send_security_reports 0 &>/dev/null; then
    ((success_count++))
    echo -e "${GREEN}Disabled security report sending for minor performance gain.${NC}"
  else
    echo -e "${YELLOW}Failed to disable security reports.${NC}"
  fi

  if [[ $success_count -gt 0 ]]; then
    echo -e "${GREEN}Application performance optimized ($success_count/$total steps completed).${NC}"
  else
    echo -e "${RED}Failed to optimize application performance.${NC}"
    return 1
  fi

  read -r -p "Do you want to reboot your device? (y/n): " reboot_choice
  case "$reboot_choice" in
    y|Y )
      echo -e "${GREEN}Rebooting device...${NC}"
      adb reboot
      ;;
    n|N )
      echo -e "${YELLOW}Warning: A reboot is recommended for optimal results.${NC}"
      ;;
    * )
      echo -e "${YELLOW}Invalid choice. No reboot performed.${NC}"
      echo -e "${YELLOW}Warning: A reboot is recommended for optimal results.${NC}"
      ;;
  esac

  read -r -p "Press Enter to return..."
}

close_background_apps() {
  check_device_connection || return 1
  echo -e "${GREEN}Closing apps in the background...${NC}"
  echo -e "${YELLOW}Note: This force-stops selected apps, but services may restart. Use cautiously as it may affect notifications or background tasks.${NC}"
  
  # List all packages
  local packages
  packages=$(adb shell pm list packages | sed 's/package://g' | tr -d '\r' | sort) || { echo -e "${RED}Failed to list packages${NC}"; return 1; }
  echo -e "${GREEN}Available packages:${NC}"
  echo "$packages"
  
  # Root check
  local root_detected=false
  if adb shell "su -c 'echo rooted'" 2>/dev/null | grep -q 'rooted'; then
    root_detected=true
  fi
  
  local use_root=false
  if $root_detected; then
    read -r -p "Root detected. Use root privileges? (y/N): " confirm_root
    if [[ "$confirm_root" =~ ^[Yy]$ ]]; then
      use_root=true
    fi
  fi
  
  # Get user input for packages
  read -r -p "Enter package names to close (separated by spaces, exact names only): " input
  if [[ -z "$input" ]]; then
    echo -e "${GREEN}No packages entered. Operation canceled.${NC}"
    return 0
  fi
  
  IFS=' ' read -r -a pkgs <<< "$input"
  
  # Confirm
  echo -e "${YELLOW}Selected packages: ${pkgs[*]}${NC}"
  read -r -p "Confirm force-stop? (y/N): " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo -e "${GREEN}Operation canceled.${NC}"
    return 0
  fi
  
  local count=0
  for pkg in "${pkgs[@]}"; do
    if $use_root; then
      adb shell su -c "am force-stop $pkg" &>/dev/null
    else
      adb shell am force-stop "$pkg" &>/dev/null
    fi
    if [[ $? -eq 0 ]]; then
      ((count++))
    else
      echo -e "${RED}Failed to stop $pkg${NC}"
    fi
  done
  
  echo -e "${GREEN}Closed $count apps.${NC}"
  read -r -p "Press Enter to return..."
}


remove_ads() {
  check_device_connection || return 1
  echo -e "${GREEN}Remove ads by configuring private DNS:${NC}"
  # Check current private DNS mode
  local current_mode=$(adb shell settings get global private_dns_mode 2>/dev/null | tr -d '\r')
  local current_specifier=$(adb shell settings get global private_dns_specifier 2>/dev/null | tr -d '\r')
  echo -e "${YELLOW}Current mode: ${current_mode:-off}${NC}"
  echo -e "${YELLOW}Current specifier: ${current_specifier:-None}${NC}"
  echo "1) Disable private DNS (default)"
  echo "2) Enable AdGuard private DNS (dns.adguard.com)"
  echo "3) Enable ControlD private DNS (p2.freedns.controld.com)"
  echo "4) Enable Quad9 private DNS (dns.quad9.net)"
  echo "5) Enable NextDNS private DNS (dns.nextdns.io - basic adblock)"
  echo "6) Enable Cloudflare private DNS (one.one.one.one)"
  read -r -p "Choose (1-6): " choice
  local success=false
  case $choice in
    1)
      if adb shell settings put global private_dns_mode off &>/dev/null && adb shell settings delete global private_dns_specifier &>/dev/null; then
        echo -e "${GREEN}Private DNS disabled.${NC}"
        success=true
      else
        echo -e "${RED}Failed to disable private DNS${NC}"
      fi
      ;;
    2)
      if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier dns.adguard.com &>/dev/null; then
        clear_launcher_data
        echo -e "${GREEN}AdGuard private DNS enabled.${NC}"
        success=true
      else
        echo -e "${RED}Failed to enable AdGuard DNS${NC}"
      fi
      ;;
    3)
      if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier p2.freedns.controld.com &>/dev/null; then
        clear_launcher_data
        echo -e "${GREEN}ControlD private DNS enabled.${NC}"
        success=true
      else
        echo -e "${RED}Failed to enable ControlD DNS${NC}"
      fi
      ;;
    4)
      if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier dns.quad9.net &>/dev/null; then
        clear_launcher_data
        echo -e "${GREEN}Quad9 private DNS enabled.${NC}"
        success=true
      else
        echo -e "${RED}Failed to enable Quad9 DNS${NC}"
      fi
      ;;
    5)
      if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier dns.nextdns.io &>/dev/null; then
        clear_launcher_data
        echo -e "${GREEN}NextDNS private DNS enabled (basic config). For custom, set up on nextdns.io.${NC}"
        success=true
      else
        echo -e "${RED}Failed to enable NextDNS${NC}"
      fi
      ;;
    6)
      if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier one.one.one.one &>/dev/null; then
        clear_launcher_data
        echo -e "${GREEN}Cloudflare private DNS enabled.${NC}"
        success=true
      else
        echo -e "${RED}Failed to enable Cloudflare DNS${NC}"
      fi
      ;;
    *)
      echo -e "${RED}Invalid choice.${NC}"
      ;;
  esac
  if ! $success; then
    return 1
  fi
  read -r -p "Press Enter to return..."
}

clear_launcher_data() {
  if adb shell pm list packages | grep -q "com.google.android.apps.tv.launcherx"; then
    if adb shell pm clear com.google.android.apps.tv.launcherx &>/dev/null; then
      echo -e "${GREEN}Cleared launcherx data.${NC}"
    else
      echo -e "${RED}Failed to clear launcherx data.${NC}"
    fi
  else
    echo -e "${YELLOW}Package com.google.android.apps.tv.launcherx not found${NC}"
  fi
  if adb shell pm list packages | grep -q "com.android.providers.tv"; then
    if adb shell pm clear com.android.providers.tv &>/dev/null; then
      echo -e "${GREEN}Cleared providers.tv data.${NC}"
    else
      echo -e "${RED}Failed to clear providers.tv data.${NC}"
    fi
  else
    echo -e "${YELLOW}Package com.android.providers.tv not found${NC}"
  fi
}

check_for_updates() {
  check_device_connection || return 1
  echo -e "${GREEN}Checking for updates...${NC}"
  adb shell am start -a android.settings.SYSTEM_UPDATE_SETTINGS || { echo -e "${RED}Failed to open update settings${NC}"; return 1; }
  echo -e "${GREEN}Update settings opened on device. Check manually.${NC}"
