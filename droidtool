# === App Management ===
install_single_apk() {
  read -r -p "Path to APK: " apk

  # Sanitize: check for forbidden characters
  if echo "$apk" | grep -q '[[:space:]*?|;&'"'"'\"`$;]'; then
    echo -e "${RED}File path contains invalid characters (spaces, *, ?, |, ;, &, ', \", \`, $): $apk${NC}"
    return 1
  fi

  if [[ ! -f "$apk" ]]; then
    echo -e "${RED}File not found: $apk${NC}"
    return 1
  fi

  check_device_connection || return 1

  timeout 300 adb install "$apk" || {
    echo -e "${RED}Failed to install $apk${NC}"
    return 1
  }
  echo -e "${GREEN}APK installed successfully.${NC}"
  read -r -p "Press Enter to return..."
}

install_apk_folder() {
  read -r -p "APK folder: " dir

  # Sanitize folder path
  if echo "$dir" | grep -q '[[:space:]*?|;&'"'"'\"`$;]'; then
    echo -e "${RED}Folder path contains invalid characters: $dir${NC}"
    return 1
  fi

  if [[ ! -d "$dir" ]]; then
    echo -e "${RED}Folder not found: $dir${NC}"
    return 1
  fi

  shopt -s nullglob
  files=("$dir"/*.apk)
  shopt -u nullglob

  if [[ ${#files[@]} -eq 0 ]]; then
    echo -e "${RED}No APK files found in $dir${NC}"
    return 1
  fi

  check_device_connection || return 1

  for f in "${files[@]}"; do
    if echo "$f" | grep -q '[[:space:]*?|;&'"'"'\"`$;]'; then
      echo -e "${RED}Skipping file with invalid characters in path: $f${NC}"
      continue
    fi
    echo -e "${GREEN}Installing $f...${NC}"
    timeout 300 adb install "$f" || { echo -e "${RED}Failed to install $f${NC}"; continue; }
  done
  read -r -p "Press Enter to return..."
}

uninstall_app() {
  check_device_connection || return 1

  echo -e "${GREEN}Installed apps (current user):${NC}"
  adb shell pm list packages -3 | sed 's/package://g' | tr -d '\r' || {
    echo -e "${RED}Failed to list packages${NC}"
    return 1
  }

  echo
  read -r -p "Package name to uninstall: " pkg

  if [[ ! "$pkg" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    echo -e "${RED}Invalid package name: $pkg${NC}"
    return 1
  fi

  if ! adb shell pm list packages | grep -q "package:$pkg"; then
    echo -e "${RED}Package not found: $pkg${NC}"
    return 1
  fi

  # Uninstall for current user
  adb shell pm uninstall --user 0 "$pkg" || {
    echo -e "${RED}Failed to uninstall $pkg (system app or permission issue)${NC}"
    return 1
  }

  echo -e "${GREEN}Successfully uninstalled $pkg for current user.${NC}"
  read -r -p "Press Enter to return..."
}

batch_uninstall() {
  check_device_connection || return 1
  echo -e "${GREEN}Installed apps (current user):${NC}"
  adb shell pm list packages -3 | sed 's/package://g' | tr -d '\r' || {
    echo -e "${RED}Failed to list packages${NC}"
    return 1
  }

  echo -e "\nEnter packages to uninstall (space separated):"
  read -r -a pkgs
  for pkg in "${pkgs[@]}"; do
    if [[ ! "$pkg" =~ ^[a-zA-Z0-9._-]+$ ]]; then
      echo -e "${RED}Skipping invalid package name: $pkg${NC}"
      continue
    fi
    if ! adb shell pm list packages | grep -q "package:$pkg"; then
      echo -e "${RED}Package not found: $pkg${NC}"
      continue
    fi
    adb shell pm uninstall --user 0 "$pkg" || {
      echo -e "${RED}Failed to uninstall $pkg${NC}"
      continue
    }
    echo -e "${GREEN}Uninstalled: $pkg${NC}"
  done
  read -r -p "Press Enter to return..."
}

enable_disable_app() {
  read -r -p "Package name: " pkg
  if [[ ! "$pkg" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    echo -e "${RED}Invalid package name: $pkg${NC}"
    return 1
  fi
  check_device_connection || return 1
  if ! adb shell pm list packages | grep -q "package:$pkg"; then
    echo -e "${RED}Package not found: $pkg${NC}"
    return 1
  fi
  echo -e "1) Enable\n2) Disable"
  read -r -p "Choice: " action
  case $action in
    1)
      adb shell pm enable --user 0 "$pkg" || {
        echo -e "${RED}Failed to enable $pkg (may require root or system-level access)${NC}"
        return 1
      }
      echo -e "${GREEN}$pkg enabled for user 0.${NC}"
      ;;
    2)
      adb shell pm disable-user --user 0 "$pkg" || {
        echo -e "${RED}Failed to disable $pkg${NC}"
        return 1
      }
      echo -e "${GREEN}$pkg disabled for user 0.${NC}"
      ;;
    *)
      echo -e "${RED}Invalid choice.${NC}"
      ;;
  esac
  read -r -p "Press Enter to return..."
}

# Requires root access
clear_cache_all() {
  check_device_connection || return 1
  check_root_access || return 1
  echo -e "${GREEN}Clearing normal app cache for all apps (without clearing app data)...${NC}"
  if ! adb shell "su -c 'for pkg in \$(pm list packages | cut -d\":\" -f2); do rm -rf /data/data/\$pkg/cache/* 2>/dev/null; done'" &>/dev/null; then
    echo -e "${RED}Failed to clear app caches. Root access may be unavailable or some caches could not be cleared.${NC}"
    return 1
  fi
  echo -e "${GREEN}App caches cleared successfully.${NC}"
  read -r -p "Press Enter to return..."
}

extract_apk() {
  read -r -p "Package name: " pkg

  if ! [[ "$pkg" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    echo -e "${RED}Invalid package name: $pkg${NC}"
    return 1
  fi

  check_device_connection || return 1

  if ! adb shell pm list packages | grep -q "package:$pkg"; then
    echo -e "${RED}Package not found: $pkg${NC}"
    return 1
  fi

  path=$(adb shell pm path "$pkg" | awk -F':' '{print $2}' | tr -d '\r' | head -n 1)

  if [[ $(adb shell pm path "$pkg" | wc -l) -gt 1 ]]; then
    echo -e "${YELLOW}Warning: Multiple APKs found for $pkg. Pulling first one.${NC}"
  fi

  if [[ -z "$path" ]]; then
    echo -e "${RED}Failed to find APK path for $pkg${NC}"
    return 1
  fi

  # Sanitize path
  if ! [[ "$path" =~ ^[a-zA-Z0-9_/.~-]+$ ]]; then
    echo -e "${RED}APK path contains invalid characters: $path${NC}"
    return 1
  fi

  timeout 300 adb pull "$path" || {
    echo -e "${RED}Failed to pull APK for $pkg${NC}"
    return 1
  }
  echo -e "${GREEN}APK extracted successfully.${NC}"
  read -r -p "Press Enter to return..."
}

# Requires root access
push_as_system_app() {
  read -r -p "Path to APK: " apk

  if ! [[ "$apk" =~ ^[a-zA-Z0-9_/.~-]+$ ]]; then
    echo -e "${RED}File path contains invalid characters: $apk${NC}"
    return 1
  fi

  read -r -p "Target folder (/system/app or /system/priv-app): " target
  if [[ "$target" != "/system/app" && "$target" != "/system/priv-app" ]]; then
    echo -e "${RED}Invalid target folder. Use /system/app or /system/priv-app.${NC}"
    return 1
  fi

  if [[ ! -f "$apk" ]]; then
    echo -e "${RED}File not found: $apk${NC}"
    return 1
  fi

  check_device_connection || return 1
  check_root_access || return 1

  # Ensure adbd is running as root
  adb root || { echo -e "${RED}Failed to gain root on ADB daemon${NC}"; return 1; }
  sleep 1

  adb remount | grep -q "remount succeeded" || {
    echo -e "${RED}Failed to remount system partition${NC}"
    return 1
  }

  timeout 300 adb push "$apk" "$target/" || {
    echo -e "${RED}Failed to push $apk to $target${NC}"
    return 1
  }

  echo -e "${GREEN}APK pushed to $target. Reboot required to apply changes.${NC}"
