push_file() {
  check_device_connection || return 1
  read -r -p "Local file path: " src
  read -r -p "Remote destination (e.g. /storage/emulated/0/Download/): " dst

  if [[ ! -f "$src" ]]; then
    echo -e "${RED}Local file not found: $src${NC}"
    return 1
  fi

  if [[ -z "$dst" || ! "$dst" =~ ^/[a-zA-Z0-9_/.~-]+$ ]]; then
    echo -e "${RED}Invalid remote destination.${NC}"
    return 1
  fi

  # Suggest using /storage/emulated/0 instead of /sdcard
  if [[ "$dst" == "/sdcard/"* ]]; then
    echo -e "${YELLOW}Note: /sdcard is a symlink. Using /storage/emulated/0 is more reliable.${NC}"
  fi

  echo -e "${GREEN}Pushing $src -> $dst...${NC}"
  if ! timeout 300 adb push "$src" "$dst"; then
    echo -e "${RED}Failed to push $src${NC}"
    return 1
  fi
  echo -e "${GREEN}Successfully pushed: $src${NC}"
  read -r -p "Press Enter to return..."
