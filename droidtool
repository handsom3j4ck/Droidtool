tv_tweaks() {
  check_device_connection || return 1
  local backup_file="$(dirname "$0")/tv_tweaks_backup.txt"
  local sdk=$(adb shell getprop ro.build.version.sdk 2>/dev/null | tr -d '\r' | xargs)
  if [[ "$sdk" -lt 28 ]]; then
    echo -e "${RED}This function is only for Android 9 (API 28) and above. Your device is API $sdk.${NC}"
    return 1
  fi
  echo -e "${YELLOW}Detected Android API level: $sdk.${NC}"
  backup_setting() {
    local ns="$1"
    local key="$2"
    local file="$3"
    local value=$(adb shell settings get "$ns" "$key" 2>/dev/null | tr -d '\r' | xargs)
    if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
      echo -e "${YELLOW}Failed to get $ns $key.${NC}"
    else
      echo "$ns:$key=$value" >> "$file"
      backed_up_global["$key"]=1
    fi
  }
  backup_cmd_power() {
    local get_cmd="$1"
    local value_name="$2"
    local file="$3"
    local value=$(adb shell cmd power "$get_cmd" 2>/dev/null | tr -d '\r' | xargs)
    if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
      echo -e "${YELLOW}Failed to get cmd power $value_name.${NC}"
    else
      echo "cmdpower:$value_name=$value" >> "$file"
      backed_up_cmd["$value_name"]=1
    fi
  }
  while true; do
    echo ""
    echo -e "${GREEN}TV Tweaks Menu:${NC}"
    echo "1. Apply Tweaks"
    echo "2. Undo Tweaks"
    echo "3. Exit"
    read -r -p "Choose an option: " choice
    case "$choice" in
      1)
        echo -e "${RED}Warning: This could damage your device. Use at your own risk.${NC}"
        read -r -p "Do you want to proceed? (y/n): " confirm
        case "$confirm" in
          y|Y ) ;;
          n|N ) echo -e "${YELLOW}Returning to menu.${NC}"; continue ;;
          * ) echo -e "${YELLOW}Invalid choice. Returning to menu.${NC}"; continue ;;
        esac
        echo -e "${YELLOW}Saving current settings before applying tweaks...${NC}"
        local temp_backup="$backup_file.temp"
        declare -A backed_up_global backed_up_cmd
        > "$temp_backup" # Clear the temp backup file
        # Define global settings to backup
        declare -a global_settings=(
          "cached_apps_freezer"
          "window_animation_scale"
          "transition_animation_scale"
          "animator_duration_scale"
          "app_auto_restriction_enabled"
          "adaptive_battery_management_enabled"
          "app_standby_enabled"
        )
        if [[ "$sdk" -ge 29 ]]; then
          global_settings+=("dynamic_power_savings_enabled")
        fi
        if [[ "$sdk" -ge 30 ]]; then
          global_settings+=("peak_refresh_rate")
        fi
        if [[ "$sdk" -ge 31 ]]; then
          global_settings+=("disable_window_blurs" "accessibility_reduce_transparency")
        fi
        # Backup global settings
        for key in "${global_settings[@]}"; do
          backup_setting global "$key" "$temp_backup"
        done
        # Backup cmd power settings
        if [[ "$sdk" -ge 29 ]]; then
          backup_cmd_power "get-adaptive-power-saver-enabled" "adaptive_power_saver" "$temp_backup"
        fi
        if [[ "$sdk" -ge 34 ]]; then
          backup_cmd_power "get-fixed-performance-mode-enabled" "fixed_performance_mode" "$temp_backup"
        fi
        if [[ -s "$temp_backup" ]]; then
          mv "$temp_backup" "$backup_file"
          echo -e "${GREEN}Backup saved to $backup_file${NC}"
        else
          rm -f "$temp_backup"
          echo -e "${RED}Backup incomplete. No reversible tweaks will be applied.${NC}"
        fi
        echo -e "${GREEN}Applying TV tweaks for performance improvements...${NC}"
        echo -e "${YELLOW}This may take a while.${NC}"
        local success_count=0
        local total=0
        local reversible_success=0
        declare -a skipped_reversible=()
        # Background dexopt job (supported on Android 8+, safe for TV to pre-optimize apps)
        ((total++))
        if adb shell cmd package bg-dexopt-job &>/dev/null; then
          ((success_count++))
          echo -e "${GREEN}Background dexopt job completed.${NC}"
        else
          echo -e "${YELLOW}Failed to run background dexopt (may not be supported).${NC}"
        fi
        # Cached apps freezer for Android 11+ (disabled for better app resumption on TV)
        if [[ "$sdk" -ge 30 ]]; then
          if [[ "${backed_up_global[cached_apps_freezer]}" ]]; then
            ((total++))
            if adb shell settings put global cached_apps_freezer disabled &>/dev/null; then
              ((success_count++))
              ((reversible_success++))
              echo -e "${GREEN}Disabled cached apps freezer for faster app resumption.${NC}"
            else
              echo -e "${YELLOW}Failed to disable cached_apps_freezer (may not be supported)${NC}";
              skipped_reversible+=("Disable cached apps freezer - failed to apply")
            fi
          else
            echo -e "${YELLOW}Skipping cached_apps_freezer (could not backup)${NC}"
            skipped_reversible+=("Disable cached apps freezer")
          fi
        else
          echo -e "${YELLOW}Skipping cached_apps_freezer (requires Android 11+)${NC}"
        fi
        # Animation tweaks (disabled for maximum snappiness on TV)
        if [[ "${backed_up_global[window_animation_scale]}" ]]; then
          ((total++))
          if adb shell settings put global window_animation_scale 0.0 &>/dev/null; then
            ((success_count++))
            ((reversible_success++))
            echo -e "${GREEN}Disabled window animations.${NC}"
          else
            echo -e "${YELLOW}Failed to disable window animations${NC}";
            skipped_reversible+=("Disable window animations - failed to apply")
          fi
        else
          echo -e "${YELLOW}Skipping window_animation_scale (could not backup)${NC}"
          skipped_reversible+=("Disable window animations")
        fi
        if [[ "${backed_up_global[transition_animation_scale]}" ]]; then
          ((total++))
          if adb shell settings put global transition_animation_scale 0.0 &>/dev/null; then
            ((success_count++))
            ((reversible_success++))
            echo -e "${GREEN}Disabled transition animations.${NC}"
          else
            echo -e "${YELLOW}Failed to disable transition animations${NC}";
            skipped_reversible+=("Disable transition animations - failed to apply")
          fi
        else
          echo -e "${YELLOW}Skipping transition_animation_scale (could not backup)${NC}"
          skipped_reversible+=("Disable transition animations")
        fi
        if [[ "${backed_up_global[animator_duration_scale]}" ]]; then
          ((total++))
          if adb shell settings put global animator_duration_scale 0.0 &>/dev/null; then
            ((success_count++))
            ((reversible_success++))
            echo -e "${GREEN}Disabled animator duration.${NC}"
          else
            echo -e "${YELLOW}Failed to disable animator duration${NC}";
            skipped_reversible+=("Disable animator duration - failed to apply")
          fi
        else
          echo -e "${YELLOW}Skipping animator_duration_scale (could not backup)${NC}"
          skipped_reversible+=("Disable animator duration")
        fi
        # Trim app caches (safe, frees storage for better performance)
        ((total++))
        if adb shell pm trim-caches 999G &>/dev/null; then
          ((success_count++))
          echo -e "${GREEN}Trimmed app caches.${NC}"
        else
          echo -e "${YELLOW}Failed to trim app caches (may not be supported)${NC}";
        fi
        # Disable adaptive power saver (Android 10+, reduces dynamic throttling for consistent speed)
        if [[ $sdk -ge 29 ]]; then
          if [[ "${backed_up_cmd[adaptive_power_saver]}" ]]; then
            ((total++))
            if adb shell cmd power set-adaptive-power-saver-enabled false &>/dev/null; then
              ((success_count++))
              ((reversible_success++))
              echo -e "${GREEN}Disabled adaptive power saver.${NC}"
            else
              echo -e "${YELLOW}Failed to disable adaptive power saver (may not be supported)${NC}"
              skipped_reversible+=("Disable adaptive power saver - failed to apply")
            fi
          else
            echo -e "${YELLOW}Skipping adaptive power saver (could not backup)${NC}"
            skipped_reversible+=("Disable adaptive power saver")
          fi
          if [[ "${backed_up_global[dynamic_power_savings_enabled]}" ]]; then
            ((total++))
            if adb shell settings put global dynamic_power_savings_enabled 0 &>/dev/null; then
              ((success_count++))
              ((reversible_success++))
              echo -e "${GREEN}Disabled dynamic power savings for consistent performance.${NC}"
            else
              echo -e "${YELLOW}Failed to disable dynamic power savings (may not be supported).${NC}"
              skipped_reversible+=("Disable dynamic power savings - failed to apply")
            fi
          else
            echo -e "${YELLOW}Skipping dynamic power savings (could not backup).${NC}"
            skipped_reversible+=("Disable dynamic power savings")
          fi
        else
          echo -e "${YELLOW}Skipping adaptive power saver (requires Android 10+)${NC}"
        fi
        # Force peak refresh rate (Android 11+, for smoother display)
        if [[ $sdk -ge 30 ]]; then
          if [[ "${backed_up_global[peak_refresh_rate]}" ]]; then
            ((total++))
            local max_rate=$(adb shell "dumpsys display | tr ',' '\n' | awk -F= '/^ fps/ {v[\$2]=1} END {for (r in v) print r}'" 2>/dev/null | sort -nr | head -1 | tr -d '\r' | xargs)
            if [[ -z "$max_rate" || ! "$max_rate" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
              max_rate=60.0
              echo -e "${YELLOW}Could not detect max refresh rate, defaulting to 60Hz.${NC}"
            fi
            if adb shell settings put global peak_refresh_rate "$max_rate" &>/dev/null; then
              ((success_count++))
              ((reversible_success++))
              echo -e "${GREEN}Forced peak refresh rate to ${max_rate}Hz for smoother display.${NC}"
            else
              echo -e "${YELLOW}Failed to force peak refresh rate (may not be supported).${NC}"
              skipped_reversible+=("Force peak refresh rate - failed to apply")
            fi
          else
            echo -e "${YELLOW}Skipping peak refresh rate (could not backup).${NC}"
            skipped_reversible+=("Force peak refresh rate")
          fi
        else
          echo -e "${YELLOW}Skipping peak refresh rate tweak (requires Android 11+).${NC}"
        fi
        # Enable fixed performance mode (Android 14+, for consistent CPU/GPU performance)
        if [[ $sdk -ge 34 ]]; then
          if [[ "${backed_up_cmd[fixed_performance_mode]}" ]]; then
            ((total++))
            if adb shell cmd power set-fixed-performance-mode-enabled true &>/dev/null; then
              ((success_count++))
              ((reversible_success++))
              echo -e "${GREEN}Enabled fixed performance mode.${NC}"
            else
              echo -e "${YELLOW}Failed to enable fixed performance mode (may not be supported)${NC}"
              skipped_reversible+=("Enable fixed performance mode - failed to apply")
            fi
          else
            echo -e "${YELLOW}Skipping fixed performance mode (could not backup)${NC}"
            skipped_reversible+=("Enable fixed performance mode")
          fi
        else
          echo -e "${YELLOW}Skipping fixed performance mode (requires Android 14+)${NC}"
        fi
        # Disable app auto-restrictions to allow better responsiveness (real global setting, safe)
        if [[ "${backed_up_global[app_auto_restriction_enabled]}" ]]; then
          ((total++))
          if adb shell settings put global app_auto_restriction_enabled false &>/dev/null; then
            ((success_count++))
            ((reversible_success++))
            echo -e "${GREEN}Disabled app auto restrictions.${NC}"
          else
            echo -e "${YELLOW}Failed to disable app restrictions (may not be supported)${NC}"
            skipped_reversible+=("Disable app auto restrictions - failed to apply")
          fi
        else
          echo -e "${YELLOW}Skipping app auto restrictions (could not backup)${NC}"
          skipped_reversible+=("Disable app auto restrictions")
        fi
        # Disable adaptive battery (safe for performance over battery on plugged-in TV, Android 9+)
        if [[ "${backed_up_global[adaptive_battery_management_enabled]}" ]]; then
          ((total++))
          if adb shell settings put global adaptive_battery_management_enabled 0 &>/dev/null; then
            ((success_count++))
            ((reversible_success++))
            echo -e "${GREEN}Disabled adaptive battery for better performance.${NC}"
          else
            echo -e "${YELLOW}Failed to disable adaptive battery.${NC}"
            skipped_reversible+=("Disable adaptive battery - failed to apply")
          fi
        else
          echo -e "${YELLOW}Skipping adaptive battery (could not backup).${NC}"
          skipped_reversible+=("Disable adaptive battery")
        fi
        # Disable app standby (allows unrestricted app access, safe for always-on TV scenarios)
        if [[ "${backed_up_global[app_standby_enabled]}" ]]; then
          ((total++))
          if adb shell settings put global app_standby_enabled 0 &>/dev/null; then
            ((success_count++))
            ((reversible_success++))
            echo -e "${GREEN}Disabled app standby for unrestricted background apps.${NC}"
          else
            echo -e "${YELLOW}Failed to disable app standby (may not be supported).${NC}"
            skipped_reversible+=("Disable app standby - failed to apply")
          fi
        else
          echo -e "${YELLOW}Skipping app standby (could not backup).${NC}"
          skipped_reversible+=("Disable app standby")
        fi
        # Android 12+ UI tweaks (safe for reducing visual effects on TV)
        if [[ "$sdk" -ge 31 ]]; then
          if [[ "${backed_up_global[disable_window_blurs]}" ]]; then
            ((total++))
            if adb shell settings put global disable_window_blurs 1 &>/dev/null; then
              ((success_count++))
              ((reversible_success++))
              echo -e "${GREEN}Disabled window blurs.${NC}"
            else
              echo -e "${YELLOW}Failed to disable window blurs (may not be supported)${NC}";
              skipped_reversible+=("Disable window blurs - failed to apply")
            fi
          else
            echo -e "${YELLOW}Skipping disable window blurs (could not backup)${NC}"
            skipped_reversible+=("Disable window blurs")
          fi
          if [[ "${backed_up_global[accessibility_reduce_transparency]}" ]]; then
            ((total++))
            if adb shell settings put global accessibility_reduce_transparency 1 &>/dev/null; then
              ((success_count++))
              ((reversible_success++))
              echo -e "${GREEN}Reduced transparency.${NC}"
            else
              echo -e "${YELLOW}Failed to reduce transparency (may not be supported)${NC}";
              skipped_reversible+=("Reduce transparency - failed to apply")
            fi
          else
            echo -e "${YELLOW}Skipping reduce transparency (could not backup)${NC}"
            skipped_reversible+=("Reduce transparency")
          fi
        else
          echo -e "${YELLOW}Skipping window blurs and transparency tweaks (requires Android 12+)${NC}"
        fi
        if [[ $success_count -eq $total && ${#skipped_reversible[@]} -eq 0 ]]; then
          echo -e "${GREEN}All TV tweaks applied successfully.${NC}"
          echo -e "${GREEN}All Tweaks are successfully applied device needs a reboot press enter to reboot${NC}"
          read -r -p ""
          echo -e "${GREEN}Rebooting device...${NC}"
          adb reboot
          exit 0
        elif [[ $success_count -gt 0 ]]; then
          if [[ $reversible_success -gt 0 ]]; then
            echo -e "${YELLOW}Applied $success_count out of $total tweaks (some may not be supported on your device).${NC}"
          else
            echo -e "${YELLOW}Only non-reversible tweaks could be applied.${NC}"
            if [[ ${#skipped_reversible[@]} -gt 0 ]]; then
              echo -e "${YELLOW}The following reversible tweaks could not be applied:${NC}"
              for tweak in "${skipped_reversible[@]}"; do
                echo "  - $tweak"
              done
            fi
          fi
          echo -e "${GREEN}Device needs a reboot. Press enter to reboot.${NC}"
          read -r -p ""
          echo -e "${GREEN}Rebooting device...${NC}"
          adb reboot
          exit 0
        else
          echo -e "${RED}Failed to apply any TV tweaks.${NC}"
        fi
        read -r -p "Press Enter to return to menu..."
        ;;
      2)
        if [[ ! -f "$backup_file" || ! -s "$backup_file" ]]; then
          echo -e "${RED}No valid backup file found. Cannot undo. Apply tweaks first.${NC}"
          read -r -p "Press Enter to return to menu..."
          continue
        fi
        echo -e "${YELLOW}Undoing TV tweaks by restoring original values...${NC}"
        declare -A cmd_power_setcmds=(
          ["adaptive_power_saver"]="set-adaptive-power-saver-enabled"
          ["fixed_performance_mode"]="set-fixed-performance-mode-enabled"
        )
        local undo_success=0
        local undo_total=0
        while IFS= read -r line; do
          if [[ -z "$line" || ! "$line" =~ = ]]; then continue; fi
          ((undo_total++))
          IFS='=' read -r type_key value <<< "$line"
          if [[ "$type_key" =~ ^(global):(.*)$ ]]; then
            local ns="${BASH_REMATCH[1]}"
            local key="${BASH_REMATCH[2]}"
            if [[ "$value" == "null" ]]; then
              if adb shell "settings delete $ns $key" &>/dev/null; then
                echo -e "${GREEN}Deleted $ns $key (original not set).${NC}"
                ((undo_success++))
              else
                echo -e "${YELLOW}Failed to delete $ns $key (may not be supported).${NC}"
              fi
            else
              if adb shell "settings put $ns $key "$value"" &>/dev/null; then
                echo -e "${GREEN}Restored $ns $key to '$value'.${NC}"
                ((undo_success++))
              else
                echo -e "${YELLOW}Failed to restore $ns $key (may not be supported).${NC}"
              fi
            fi
          elif [[ "$type_key" =~ ^cmdpower:(.*)$ ]]; then
            local varname="${BASH_REMATCH[1]}"
            local setcmd="${cmd_power_setcmds[$varname]}"
            if [[ -n "$setcmd" ]] && [[ -n "$value" ]] && adb shell "cmd power $setcmd $value" &>/dev/null; then
              echo -e "${GREEN}Restored cmd power $varname to '$value'.${NC}"
              ((undo_success++))
            else
              echo -e "${YELLOW}Failed to restore cmd power $varname (may not be supported).${NC}"
            fi
          fi
        done < "$backup_file"
        if [[ $undo_success -eq $undo_total ]]; then
          echo -e "${GREEN}All restorable TV tweaks undone successfully.${NC}"
          echo -e "${YELLOW}Note: Cache trims are not reversible.${NC}"
          echo -e "${GREEN}All Tweaks are successfully undone device needs a reboot press enter to reboot${NC}"
          read -r -p ""
          echo -e "${GREEN}Rebooting device...${NC}"
          adb reboot
          exit 0
        elif [[ $undo_success -gt 0 ]]; then
          echo -e "${YELLOW}Restored $undo_success out of $undo_total settings (some may not be supported).${NC}"
          echo -e "${YELLOW}Note: Cache trims are not reversible.${NC}"
          echo -e "${GREEN}Device needs a reboot. Press enter to reboot.${NC}"
          read -r -p ""
          echo -e "${GREEN}Rebooting device...${NC}"
          adb reboot
          exit 0
        else
          echo -e "${RED}Failed to undo any TV tweaks.${NC}"
        fi
        read -r -p "Press Enter to return to menu..."
        ;;
      3)
        return 0
        ;;
      *)
        echo -e "${YELLOW}Invalid choice.${NC}"
        read -r -p "Press Enter to continue..."
        ;;
    esac
  done
}

tv_debloat() {
