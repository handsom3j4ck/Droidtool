    echo "7) Check for TV device updates"
    echo "8) Remove ads (could require root)"
    echo "9) Delete app data and cache (per app)"
    echo "10) Back to main menu"
    read -r -p "Choose (1-10): " c
    case $c in
      1) apply_general_performance_improvements ;;
      2) enable_processing_speed_management ;;
      3) delete_cache_memory ;;
      4) optimize_app_performance ;;
      5) close_background_apps ;;
