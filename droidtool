sideload_zip() {
  read -r -p "ZIP file path: " zip

  # Sanitize
  if ! [[ "$zip" =~ ^[a-zA-Z0-9_/.~-]+$ ]]; then
    echo -e "${RED}File path contains invalid characters: $zip${NC}"
    return 1
  fi

  # Check if file exists and has .zip extension
  if [[ ! -f "$zip" ]]; then
    echo -e "${RED}File not found: $zip${NC}"
    return 1
  fi

  if ! [[ "$zip" =~ \.zip$ ]]; then
    echo -e "${RED}Invalid file type. Only .zip files are allowed: $zip${NC}"
    return 1
  fi

  # Check ADB state
  if ! adb get-state | grep -q "recovery"; then
    echo -e "${RED}Device is not in recovery mode. Please boot into recovery first.${NC}"
    return 1
  fi

  if ! adb devices | grep -q "sideload"; then
    echo -e "${RED}Device is not in sideload mode. Please enable ADB sideload in recovery.${NC}"
    return 1
  fi

  echo -e "${GREEN}Starting sideload...${NC}"
  timeout 600 adb sideload "$zip" || {
    echo -e "${RED}Failed to sideload $zip or timed out${NC}"
    return 1
  }

  echo -e "${GREEN}Sideload completed successfully.${NC}"
  read -r -p "Press Enter to return..."
