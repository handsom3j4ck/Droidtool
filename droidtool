disable_bloatware() {
  check_device_connection || return 1

  echo -e "${GREEN}Installed apps (current user):${NC}"
  adb shell pm list packages -3 | sed 's/package://g' | tr -d '\r' || {
    echo -e "${RED}Failed to list packages${NC}"
    return 1
  }

  echo
  echo -e "${GREEN}Enter package names to disable (space-separated):${NC}"
  read -r -a pkgs

  if [[ ${#pkgs[@]} -eq 0 ]]; then
    echo -e "${RED}No package names entered.${NC}"
    sleep 1
    return 1
  fi

  for pkg in "${pkgs[@]}"; do
    # Trim carriage returns
    pkg=${pkg//$'\r'/}

    if [[ -z "$pkg" ]]; then
      continue
    fi

    if [[ ! "$pkg" =~ ^[a-zA-Z0-9._-]+$ ]]; then
      echo -e "${RED}Invalid package name: $pkg${NC}"
      continue
    fi

    if ! adb shell pm list packages | grep -q "package:$pkg"; then
      echo -e "${RED}Package not found: $pkg${NC}"
      continue
    fi

    if adb shell pm disable-user --user 0 "$pkg" &>/dev/null; then
      echo -e "${GREEN}Successfully disabled: $pkg${NC}"
    else
      echo -e "${RED}Failed to disable: $pkg (may require root or system app restrictions)${NC}"
    fi
  done

  read -r -p "Press Enter to return..."
}

