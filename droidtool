# Toggle Dark Mode (Android 10+)
toggle_dark_mode() {
  check_device_connection || return 1
  local sdk=$(adb shell getprop ro.build.version.sdk 2>/dev/null | tr -d '\r' | xargs)
  if [[ "$sdk" -lt 29 ]]; then
    echo -e "${RED}Dark mode toggle requires Android 10 (SDK 29) or higher.${NC}"
    return 1
  fi
  echo -e "${GREEN}Toggle System Dark Mode (Android 10+)${NC}"
  # Check current mode for better user experience
  local current_mode=$(adb shell settings get secure ui_night_mode 2>/dev/null | tr -d '\r')
  case $current_mode in
    0) echo -e "${YELLOW}Current mode: Auto${NC}" ;;
    1) echo -e "${YELLOW}Current mode: Light${NC}" ;;
    2) echo -e "${YELLOW}Current mode: Dark${NC}" ;;
    *) echo -e "${YELLOW}Current mode: Unknown${NC}" ;;
  esac
  if [[ "$current_mode" == "0" && "$sdk" -ge 36 ]]; then
    echo -e "${YELLOW}Note: Auto mode may have issues in Android 16 due to known bugs.${NC}"
  fi
  echo "1) Dark Mode"
  echo "2) Light Mode"
  echo "3) Auto (based on system)"
  read -r -p "Choose: " mode
  case $mode in
    1) 
      if adb shell settings put secure ui_night_mode 2; then
        adb shell cmd uimode night apply || { echo -e "${YELLOW}Failed to apply theme, but setting changed.${NC}"; }
        echo -e "${GREEN}Dark mode enabled.${NC}"
      else
        echo -e "${RED}Failed to enable dark mode.${NC}"
        return 1
      fi
      ;;
    2) 
      if adb shell settings put secure ui_night_mode 1; then
        adb shell cmd uimode night apply || { echo -e "${YELLOW}Failed to apply theme, but setting changed.${NC}"; }
        echo -e "${GREEN}Light mode enabled.${NC}"
      else
        echo -e "${RED}Failed to enable light mode.${NC}"
        return 1
      fi
      ;;
    3) 
      if adb shell settings put secure ui_night_mode 0; then
        adb shell cmd uimode night apply || { echo -e "${YELLOW}Failed to apply theme, but setting changed.${NC}"; }
        echo -e "${GREEN}Auto mode enabled.${NC}"
        if [[ "$sdk" -ge 36 ]]; then
          echo -e "${YELLOW}Note: Auto mode may not toggle correctly at sunset/sunrise in Android 16.${NC}"
        fi
      else
        echo -e "${RED}Failed to enable auto mode.${NC}"
        return 1
      fi
      ;;
    *) echo -e "${RED}Invalid choice${NC}"; sleep 1; return 1 ;;
  esac
  read -r -p "Press Enter to return..."
}

# === Custom Settings for Android TV/Google TV ===
custom_settings_menu() {
  while true; do
    clear
    echo -e "\n${GREEN}Custom Settings for Android TV/Google TV:${NC}"
    echo "1) Apply general-purpose performance improvements"
    echo "2) Enable processing speed management system"
    echo "3) Optimize application performance"
    echo "4) Close apps in the background"
    echo "5) Check for TV device updates"
    echo "6) Remove ads via private DNS"
    echo "7) Delete app data and cache (per app)"
    echo "8) Back to main menu"
    read -r -p "Choose (1-8): " c
    case $c in
      1) apply_general_performance_improvements ;;
      2) enable_processing_speed_management ;;
      3) optimize_app_performance ;;
      4) close_background_apps ;;
      5) check_for_updates ;;
      6) remove_ads ;;
      7) delete_app_data_cache ;;
      8) break ;;
      *) echo -e "${RED}Invalid choice.${NC}" ;;
    esac
  done
}

apply_general_performance_improvements() {
  check_device_connection || return 1
  local sdk=$(adb shell getprop ro.build.version.sdk 2>/dev/null | tr -d '\r' | xargs)
  echo -e "${GREEN}Applying general-purpose performance improvements...${NC}"
  if [[ "$sdk" -lt 28 ]]; then
    echo -e "${YELLOW}Some tweaks may not be supported on Android versions below 9.${NC}"
  fi
  local success_count=0
  local total=7

  if adb shell settings put global cached_apps_freezer enabled &>/dev/null; then ((success_count++)); else echo -e "${YELLOW}Failed to set cached_apps_freezer (may not be supported)${NC}"; fi
  if adb shell settings put secure tap_duration_threshold 0.0 &>/dev/null; then ((success_count++)); else echo -e "${YELLOW}Failed to set tap_duration_threshold (may not be supported)${NC}"; fi
  if adb shell settings put secure touch_blocking_period 0.0 &>/dev/null; then ((success_count++)); else echo -e "${YELLOW}Failed to set touch_blocking_period (may not be supported)${NC}"; fi
  if adb shell settings put global window_animation_scale 0.0 &>/dev/null; then ((success_count++)); else echo -e "${YELLOW}Failed to disable window animations${NC}"; fi
  if adb shell settings put global transition_animation_scale 0.0 &>/dev/null; then ((success_count++)); else echo -e "${YELLOW}Failed to disable transition animations${NC}"; fi
  if adb shell settings put global animator_duration_scale 0.0 &>/dev/null; then ((success_count++)); else echo -e "${YELLOW}Failed to disable animator duration${NC}"; fi
  if adb shell settings put global always_finish_activities 1 &>/dev/null; then ((success_count++)); else echo -e "${YELLOW}Failed to set always finish activities${NC}"; fi

  if [[ $success_count -eq $total ]]; then
    echo -e "${GREEN}All performance improvements applied successfully.${NC}"
  elif [[ $success_count -gt 0 ]]; then
    echo -e "${YELLOW}Applied $success_count out of $total improvements (some may not be supported on your device).${NC}"
  else
    echo -e "${RED}Failed to apply any performance improvements.${NC}"
    return 1
  fi
  read -r -p "Press Enter to return..."
}

enable_processing_speed_management() {
  check_device_connection || return 1
  local brand=$(adb shell getprop ro.product.brand 2>/dev/null | tr -d '\r' | xargs | tr '[:upper:]' '[:lower:]')
  echo -e "${GREEN}Enabling processing speed management system...${NC}"
  local success=false
  if [[ "$brand" == "samsung" ]]; then
    if adb shell settings put global sem_enhanced_cpu_responsiveness 1 &>/dev/null; then
      echo -e "${GREEN}Samsung-specific CPU responsiveness enabled.${NC}"
      success=true
    else
      echo -e "${RED}Failed to enable CPU responsiveness${NC}"
    fi
  else
    echo -e "${YELLOW}Device brand is $brand (not Samsung). Applying general tweaks.${NC}"
    if adb shell settings put global debug.performance.tuning 1 &>/dev/null; then
      echo -e "${GREEN}General performance tuning enabled.${NC}"
      success=true
    else
      echo -e "${YELLOW}Failed to set performance tuning (may not be supported)${NC}"
    fi
  fi
  if is_rooted; then
    echo -e "${GREEN}Device is rooted. Setting CPU governor to performance...${NC}"
    if adb shell "su -c 'for i in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do echo performance > \$i; done'" &>/dev/null; then
      echo -e "${GREEN}CPU governor set to performance on all cores.${NC}"
      success=true
    else
      echo -e "${YELLOW}Failed to set CPU governor.${NC}"
    fi
  fi
  if $success; then
    echo -e "${GREEN}Processing speed management enabled.${NC}"
  else
    echo -e "${RED}Failed to enable processing speed management.${NC}"
