#!/bin/bash

# Droidtool Linux Android Tool
# Requirements: android-tools-adb, android-tools-fastboot

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

# Clean up ADB server on script termination
trap 'adb kill-server &>/dev/null; echo -e "${RED}Script terminated. ADB server stopped.${NC}"; exit 1' SIGINT SIGTERM
trap 'adb kill-server &>/dev/null' EXIT

# Get script directory
SCRIPT_DIR=$(dirname "$(realpath "$0")")

# Check device connection
check_device_connection() {
  adb start-server &>/dev/null || { echo -e "${RED}ADB server failed to start.${NC}"; return 1; }
  if ! adb devices | grep -q "device$"; then
    echo -e "${RED}No device connected. Please reconnect using the connection menu.${NC}"
    return 1
  fi
}

# Ensure android-tools is installed
install_android_tools() {
  echo -e "${GREEN}Checking for android-tools...${NC}"
  if command -v adb &>/dev/null && command -v fastboot &>/dev/null; then
    echo -e "${GREEN}android-tools is already installed.${NC}"
    return
  fi
  if [ -f /etc/debian_version ]; then
    echo -e "${GREEN}Debian/Ubuntu detected. Installing...${NC}"
    sudo apt update || { echo -e "${RED}Failed to update package lists.${NC}"; exit 1; }
    sudo apt install -y android-tools-adb android-tools-fastboot || { echo -e "${RED}Failed to install android-tools.${NC}"; exit 1; }
  elif [ -f /etc/arch-release ]; then
    echo -e "${GREEN}Arch Linux detected. Installing...${NC}"
    sudo pacman -Sy --noconfirm android-tools || { echo -e "${RED}Failed to install android-tools.${NC}"; exit 1; }
  elif [ -f /etc/fedora-release ]; then
    echo -e "${GREEN}Fedora detected. Installing...${NC}"
    sudo dnf install -y android-tools || { echo -e "${RED}Failed to install android-tools.${NC}"; exit 1; }
  elif [ -f /etc/redhat-release ] || [ -f /etc/centos-release ]; then
    echo -e "${GREEN}Red Hat/CentOS detected. Installing...${NC}"
    sudo yum install -y android-tools || { echo -e "${RED}Failed to install android-tools.${NC}"; exit 1; }
  else
    echo -e "${RED}Unsupported system. Please install android-tools manually.${NC}"
    exit 1
  fi
  if ! command -v adb &>/dev/null || ! command -v fastboot &>/dev/null; then
    echo -e "${RED}Failed to install android-tools. Please install manually.${NC}"
    exit 1
  fi
}

# ADB connection functions
connect_usb() {
  adb kill-server
  adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; exit 1; }
  echo -e "${GREEN}Looking for USB devices...${NC}"
  for i in {1..3}; do
    adb devices
    if adb devices | grep -q "unauthorized"; then
      echo -e "${RED}Device unauthorized. Please accept the ADB connection on your device (attempt $i/3).${NC}"
      sleep 5
      adb kill-server
      adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; exit 1; }
    elif adb devices | grep -q "device$"; then
      echo -e "${GREEN}Connected via USB.${NC}"
      return 0
    else
      echo -e "${RED}No device found via USB (attempt $i/3).${NC}"
      sleep 5
      adb kill-server
      adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; exit 1; }
    fi
  done
  echo -e "${RED}Failed to connect via USB after 3 attempts.${NC}"
  return 1
}

connect_ip() {
  read -r -p "Enter device IP address: " device_ip
  if [[ ! "$device_ip" =~ ^([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})$ ]] ||
     [[ ${BASH_REMATCH[1]} -gt 255 || ${BASH_REMATCH[2]} -gt 255 || ${BASH_REMATCH[3]} -gt 255 || ${BASH_REMATCH[4]} -gt 255 ]]; then
    echo -e "${RED}Invalid IP address format or range: $device_ip${NC}"
    return 1
  fi
  adb kill-server
  adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; exit 1; }
  echo -e "${GREEN}Connecting to $device_ip...${NC}"
  for i in {1..3}; do
    adb connect "$device_ip" || { echo -e "${RED}Failed to connect to $device_ip (attempt $i/3)${NC}"; sleep 5; adb kill-server; adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; exit 1; }; continue; }
    sleep 2
    if adb devices | grep -q "$(echo "$device_ip" | sed 's/\./\\./g').*unauthorized"; then
      echo -e "${RED}Device unauthorized. Please accept the ADB connection on your device (attempt $i/3).${NC}"
      sleep 5
      adb kill-server
      adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; exit 1; }
    elif adb devices | grep -q "$device_ip.*device"; then
      echo -e "${GREEN}Connected via IP.${NC}"
      return 0
    else
      echo -e "${RED}Connection to $device_ip failed (attempt $i/3).${NC}"
      sleep 5
      adb kill-server
      adb start-server || { echo -e "${RED}Failed to start ADB server. Check permissions or port conflicts.${NC}"; exit 1; }
    fi
  done
  echo -e "${RED}Failed to connect to $device_ip after 3 attempts.${NC}"
  return 1
}

# One-Click ADB Wireless Pairing (Android 11+)
adb_wireless_pair() {
  echo -e "${GREEN}Ensure device is on the same Wi-Fi and has 'Pair over Wi-Fi' enabled.${NC}"
  echo -e "${YELLOW}Settings > Developer options > ADB over network > Pairing${NC}"
  read -r -p "Enter pairing IP and port (e.g. 192.168.1.100:37521): " ip_port
  read -r -p "Enter pairing code: " code
  adb pair "$ip_port" "$code" || { echo -e "${RED}Pairing failed. Check IP:port/code.${NC}"; return 1; }
  echo -e "${GREEN}Paired successfully! Now connect via IP.${NC}"
  sleep 2
}

connection_menu() {
  echo -e "${GREEN}Select connection method:${NC}"
  echo "1) USB"
  echo "2) IP"
  echo "3) ADB Wireless Pair (Android 11+)"
  echo "4) Exit"
  read -r -p "Choose (1-4): " c
  case $c in
    1) connect_usb || { echo -e "${RED}Connection failed. Exiting.${NC}"; exit 1; } ;;
    2) connect_ip || { echo -e "${RED}Connection failed. Exiting.${NC}"; exit 1; } ;;
    3) adb_wireless_pair || { echo -e "${RED}Pairing failed. Exiting.${NC}"; exit 1; } ;;
    4) echo "Exiting."; exit 0 ;;
    *) echo -e "${RED}Invalid choice.${NC}" ; connection_menu ;;
  esac
}

# Helper function to check if device is rooted
is_rooted() {
  local test=$(adb shell "su -c 'echo yes' 2>/dev/null" | tr -d '\r')
  if [[ "$test" == "yes" ]]; then
    return 0
  else
    return 1
  fi
}

# === Device Info & System ===
show_device_report() {
  check_device_connection || return 1
  clear
  echo -e "\n${GREEN}=== Device System Report ===${NC}"
  echo

  # === Basic Device Info ===
  echo -e "${GREEN}Device Info${NC}"
  local brand=$(adb shell getprop ro.product.brand 2>/dev/null | tr -d '\r' | xargs)
  local model=$(adb shell getprop ro.product.model 2>/dev/null | tr -d '\r' | xargs)
  local release=$(adb shell getprop ro.build.version.release 2>/dev/null | tr -d '\r' | xargs)
  local sdk=$(adb shell getprop ro.build.version.sdk 2>/dev/null | tr -d '\r' | xargs)
  local serial=$(adb shell getprop ro.serialno 2>/dev/null | tr -d '\r' | xargs)
  local build=$(adb shell getprop ro.build.display.id 2>/dev/null | tr -d '\r' | xargs)
  local security_patch=$(adb shell getprop ro.build.version.security_patch 2>/dev/null | tr -d '\r' | xargs)
  local kernel=$(adb shell uname -r 2>/dev/null | tr -d '\r' | xargs)
  local rooted="No"
  if is_rooted; then rooted="Yes"; fi

  echo "  Brand:     ${brand:-Unknown}"
  echo "  Model:     ${model:-Unknown}"
  echo "  Android:   ${release:-Unknown} (SDK ${sdk:-?})"
  echo "  Serial:    ${serial:-Unknown}"
  echo "  Build:     ${build:-Unknown}"
  echo "  Security Patch: ${security_patch:-Unknown}"
  echo "  Kernel:    ${kernel:-Unknown}"
  echo "  Rooted:    $rooted"
  echo

  # === Uptime ===
  echo -e "${GREEN}Uptime${NC}"
  local uptime=$(adb shell uptime 2>/dev/null | tr -d '\r' | xargs)
  echo "  $uptime"
  echo

  # === Battery ===
  echo -e "${GREEN}Battery Status${NC}"
  local battery=$(adb shell dumpsys battery 2>/dev/null)
  if [[ -z "$battery" ]]; then
    echo "  Failed to retrieve battery info"
  else
    local level=$(echo "$battery" | grep " level:" | awk '{print $2}')
    local status=$(echo "$battery" | grep " status:" | awk '{print $2}')
    local health=$(echo "$battery" | grep " health:" | awk '{print $2}')
    local temp_raw=$(echo "$battery" | grep " temperature:" | awk '{print $2}')
    local temp="?"

    # Only process temp if value is numeric
    if [[ "$temp_raw" =~ ^[0-9]+$ ]]; then
      temp=$(awk "BEGIN {printf \"%.1f\", $temp_raw / 10}")
    fi

    case $status in
      1) status="Unknown" ;;
      2) status="Charging" ;;
      3) status="Discharging" ;;
      4) status="Not Charging" ;;
      5) status="Full" ;;
      *) status="Unknown" ;;
    esac

    case $health in
      1) health="Unknown" ;;
      2) health="Good" ;;
      3) health="Overheat" ;;
      4) health="Dead" ;;
      5) health="Over Voltage" ;;
      6) health="Unspecified Failure" ;;
      7) health="Cold" ;;
      *) health="Unknown" ;;
    esac

    echo "  Level:     ${level:-?}%"
    echo "  Status:    $status"
    echo "  Health:    $health"
    echo "  Temp:      ${temp}°C"
  fi
  echo

  # === Storage ===
  echo -e "${GREEN}Storage Usage${NC}"
  local storage=$(adb shell df -h /data /system /cache 2>/dev/null)
  if [[ -n "$storage" ]]; then
    echo "$storage" | while IFS= read -r line; do
      echo "  $line"
    done
  else
    echo "  Failed to retrieve storage info"
  fi
  echo

  # === Memory ===
  echo -e "${GREEN}Memory Info${NC}"
  local mem=$(adb shell free -h 2>/dev/null | grep Mem)
  if [[ -n "$mem" ]]; then
    echo "  $mem"
  else
    echo "  Failed to retrieve memory info"
  fi
  echo

  # === Screen ===
  echo -e "${GREEN}Screen Info${NC}"
  local resolution=$(adb shell wm size 2>/dev/null | grep "Physical size" | cut -d: -f2 | xargs)
  echo "  Resolution: ${resolution:-Unknown}"
  echo

  # ...(truncated 26269 characters)...orted on your device).${NC}"
  read -r -p "Press Enter to return..."
}

enable_processing_speed_management() {
  check_device_connection || return 1
  local brand=$(adb shell getprop ro.product.brand 2>/dev/null | tr -d '\r' | xargs | tr '[:upper:]' '[:lower:]')
  echo -e "${GREEN}Enabling processing speed management system...${NC}"
  if [[ "$brand" == "samsung" ]]; then
    adb shell settings put global sem_enhanced_cpu_responsiveness 1 || { echo -e "${RED}Failed to enable CPU responsiveness${NC}"; return 1; }
    echo -e "${GREEN}Samsung-specific CPU responsiveness enabled.${NC}"
  else
    echo -e "${YELLOW}Device brand is $brand (not Samsung). Applying general tweaks.${NC}"
    adb shell settings put global debug.performance.tuning 1 || echo -e "${YELLOW}Failed to set performance tuning (may not be supported)${NC}"
  fi
  if is_rooted; then
    echo -e "${GREEN}Device is rooted. Setting CPU governor to performance...${NC}"
    adb shell "su -c 'echo performance > /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor'" || echo -e "${YELLOW}Failed to set CPU governor.${NC}"
  fi
  echo -e "${GREEN}Processing speed management enabled.${NC}"
  read -r -p "Press Enter to return..."
}

optimize_app_performance() {
  check_device_connection || return 1
  echo -e "${GREEN}Optimizing application performance...${NC}"
  echo -e "${YELLOW}This may take a while for devices with many apps.${NC}"
  adb shell cmd package bg-dexopt-job || echo -e "${YELLOW}Failed to run background dexopt (may not be supported)${NC}"
  adb shell cmd package compile -m speed-profile -a || { echo -e "${RED}Failed to optimize apps with speed-profile${NC}"; }
  adb shell cmd package compile -m speed -a || echo -e "${YELLOW}Failed to optimize with speed mode (fallback).${NC}"
  echo -e "${GREEN}Application performance optimized.${NC}"
  read -r -p "Press Enter to return..."
}

close_background_apps() {
  check_device_connection || return 1
  echo -e "${GREEN}Closing apps in the background...${NC}"
  while read -r pkg; do
    pkg=${pkg//$'\r'/}
    adb shell am force-stop "$pkg" || { echo -e "${RED}Failed to stop $pkg${NC}"; continue; }
  done < <(adb shell pm list packages -3 | sed 's/package://g' | tr -d '\r') || { echo -e "${RED}Failed to list packages${NC}"; return 1; }
  echo -e "${GREEN}Background apps closed.${NC}"
  read -r -p "Press Enter to return..."
}

delete_cache_aio() {
  check_device_connection || return 1
  echo -e "${GREEN}Clearing cache for user-installed apps...${NC}"
  if is_rooted; then
    local count=0
    while read -r pkg; do
      pkg=${pkg//$'\r'/}
      adb shell "su -c 'rm -rf /data/data/$pkg/cache/*'" || { echo -e "${RED}Failed to clear cache for $pkg${NC}"; continue; }
      ((count++))
    done < <(adb shell pm list packages -3 | sed 's/package://g' | tr -d '\r') || { echo -e "${RED}Failed to list packages${NC}"; return 1; }
    echo -e "${GREEN}Cleared cache for $count apps.${NC}"
  else
    echo -e "${YELLOW}Device not rooted. Falling back to system-wide cache trim.${NC}"
    adb shell pm trim-caches 999G || { echo -e "${RED}Failed to trim caches.${NC}"; return 1; }
    echo -e "${GREEN}System-wide caches trimmed.${NC}"
  fi
  read -r -p "Press Enter to return..."
}

remove_ads() {
  check_device_connection || return 1
  echo -e "${GREEN}Remove ads by configuring private DNS:${NC}"
  echo "1) Disable private DNS (default)"
  echo "2) Enable AdGuard private DNS (dns.adguard.com)"
  echo "3) Enable ControlD private DNS (p2.freedns.controld.com)"
  echo "4) Enable Quad9 private DNS (dns.quad9.net)"
  echo "5) Enable NextDNS private DNS (dns.nextdns.io - basic adblock)"
  read -r -p "Choose (1-5): " choice
  case $choice in
    1)
      adb shell settings put global private_dns_mode off || { echo -e "${RED}Failed to disable private DNS${NC}"; return 1; }
      adb shell settings delete global private_dns_specifier || { echo -e "${RED}Failed to delete DNS specifier${NC}"; return 1; }
      echo -e "${GREEN}Private DNS disabled.${NC}"
      ;;
    2)
      adb shell settings put global private_dns_mode hostname || { echo -e "${RED}Failed to set private DNS mode${NC}"; return 1; }
      adb shell settings put global private_dns_specifier dns.adguard.com || { echo -e "${RED}Failed to set AdGuard DNS${NC}"; return 1; }
      clear_launcher_data
      echo -e "${GREEN}AdGuard private DNS enabled.${NC}"
      ;;
    3)
      adb shell settings put global private_dns_mode hostname || { echo -e "${RED}Failed to set private DNS mode${NC}"; return 1; }
      adb shell settings put global private_dns_specifier p2.freedns.controld.com || { echo -e "${RED}Failed to set ControlD DNS${NC}"; return 1; }
      clear_launcher_data
      echo -e "${GREEN}ControlD private DNS enabled.${NC}"
      ;;
    4)
      adb shell settings put global private_dns_mode hostname || { echo -e "${RED}Failed to set private DNS mode${NC}"; return 1; }
      adb shell settings put global private_dns_specifier dns.quad9.net || { echo -e "${RED}Failed to set Quad9 DNS${NC}"; return 1; }
      clear_launcher_data
      echo -e "${GREEN}Quad9 private DNS enabled.${NC}"
      ;;
    5)
      adb shell settings put global private_dns_mode hostname || { echo -e "${RED}Failed to set private DNS mode${NC}"; return 1; }
      adb shell settings put global private_dns_specifier dns.nextdns.io || { echo -e "${RED}Failed to set NextDNS${NC}"; return 1; }
      clear_launcher_data
      echo -e "${GREEN}NextDNS private DNS enabled (basic config). For custom, set up on nextdns.io.${NC}"
      ;;
    *)
      echo -e "${RED}Invalid choice.${NC}"
      ;;
  esac
  read -r -p "Press Enter to return..."
}

clear_launcher_data() {
  if adb shell pm list packages | grep -q "com.google.android.apps.tv.launcherx"; then
    adb shell pm clear com.google.android.apps.tv.launcherx || { echo -e "${RED}Failed to clear launcherx data.${NC}"; }
  else
    echo -e "${YELLOW}Package com.google.android.apps.tv.launcherx not found${NC}"
  fi
  if adb shell pm list packages | grep -q "com.android.providers.tv"; then
    adb shell pm clear com.android.providers.tv || { echo -e "${RED}Failed to clear providers.tv data.${NC}"; }
  else
    echo -e "${YELLOW}Package com.android.providers.tv not found${NC}"
  fi
}

# === Menus ===
main_menu() {
  while true; do
    (tput clear 2>/dev/null) || printf '\033[2J\033[H'
    echo -e "\n${GREEN}=== Droidtool Main Menu ===${NC}"
    echo "1) Device Info"
    echo "2) App Management"
    echo "3) File Management"
    echo "4) Custom Settings"
    echo "5) Developer Tools"
    echo "6) Exit"
    read -r -p "Select category (1-6): " cat
    case $cat in
      1) show_device_report ;;
      2) category_app_mgmt ;;
      3) category_files ;;
      4) custom_settings_menu ;;
      5) category_dev_tools ;;
      6) echo -e "${GREEN}Goodbye!${NC}"; exit 0 ;;
      *) echo -e "${RED}Invalid choice.${NC}" ;;
    esac
  done
}

category_app_mgmt() {
  while true; do
    clear
    echo -e "${GREEN}\n App Management:${NC}"
    echo "1) Install single APK"
    echo "2) Install multiple APKs"
    echo "3) Uninstall app"
    echo "4) Batch uninstall apps"
    echo "5) Enable/disable app"
    echo "6) Extract APK from device"
    echo "7) Disable bloatware (keep, but hide)"
    echo "8) Back to main menu"
    read -r -p "Choose (1-8): " c
    case $c in
      1) install_single_apk ;;
      2) install_apk_folder ;;
      3) uninstall_app ;;
      4) batch_uninstall ;;
      5) enable_disable_app ;;
      6) extract_apk ;;
      7) disable_bloatware ;;
      8) break ;;
      *) echo -e "${RED}Invalid choice.${NC}" ;;
    esac
  done
}

category_files() {
  while true; do
    clear
    echo -e "${GREEN}\n File Management:${NC}"
    echo "1) Pull file from device"
    echo "2) Push file to device"
    echo "3) Delete file from device"
    echo "4) Pull folder from device"
    echo "5) Push folder to device"
    echo "6) Delete folder from device"
    echo "7) Search for files on device"
    echo "8) Search for folders on device"
    echo "9) Back to main menu"
    read -r -p "Choose (1-9): " c
    case $c in
      1) pull_file ;;
      2) push_file ;;
      3) delete_file ;;
      4) pull_folder ;;
      5) push_folder ;;
      6) delete_folder ;;
      7) search_device_files ;;
      8) find_folder ;;
      9) break ;;
      *) echo -e "${RED}Invalid choice.${NC}" ;;
    esac
  done
}

category_dev_tools() {
  while true; do
    clear
    echo -e "${GREEN}\n Developer Tools:${NC}"
    echo "1) Show logcat"
    echo "2) Save logcat to file"
    echo "3) Open shell"
    echo "4) Take screenshot"
    echo "5) Toggle dark mode (Android 10+)"
    echo "6) Custom ADB command"
    echo "7) Back to main menu"
    read -r -p "Choose (1-7): " c
    case $c in
      1) logcat_viewer ;;
      2) logcat_save ;;
      3) shell_access ;;
      4) screenshot ;;
      5) toggle_dark_mode ;;
      6) custom_adb_command ;;
      7) break ;;
      *) echo -e "${RED}Invalid choice.${NC}" ;;
    esac
  done
}

check_for_updates() {
  check_device_connection || return 1
  echo -e "${GREEN}Checking for updates...${NC}"
  adb shell am start -a android.settings.SYSTEM_UPDATE_SETTINGS || { echo -e "${RED}Failed to open update settings${NC}"; return 1; }
  echo -e "${GREEN}Update settings opened on device. Check manually.${NC}"
  read -r -p "Press Enter to return..."
}

# === Script start ===
echo -e "${GREEN}=================================${NC}"
echo -e "${GREEN}             Droidtool           ${NC}"
echo -e "${GREEN}=================================${NC}"
echo -e "${NC}"
install_android_tools
connection_menu
main_menu
