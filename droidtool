close_background_apps() {
  check_device_connection || return 1
  echo -e "${GREEN}Closing apps in the background...${NC}"
  echo -e "${YELLOW}Note: This force-stops third-party apps, but services may restart. Use cautiously as it may affect notifications or background tasks.${NC}"
  read -r -p "This will force-stop all third-party apps. Confirm? (y/N): " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo -e "${GREEN}Operation canceled.${NC}"
    return 0
  fi
  local count=0
  while read -r pkg; do
    pkg=${pkg//$'\r'/}
    if adb shell am force-stop "$pkg" &>/dev/null; then
      ((count++))
    else
      echo -e "${RED}Failed to stop $pkg${NC}"
    fi
  done < <(adb shell pm list packages -3 | sed 's/package://g' | tr -d '\r') || { echo -e "${RED}Failed to list packages${NC}"; return 1; }
  echo -e "${GREEN}Closed $count background apps.${NC}"
  read -r -p "Press Enter to return..."
}

delete_app_data_cache() {
  check_device_connection || return 1
  echo -e "${GREEN}Installed packages (current user):${NC}"
  adb shell pm list packages -3 | sed 's/package://g' | tr -d '\r' || {
    echo -e "${RED}Failed to list packages${NC}"
    return 1
  }

  read -r -p "Enter package name to delete data and cache: " pkg
  if [[ ! "$pkg" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    echo -e "${RED}Invalid package name: $pkg${NC}"
    return 1
  fi
  if ! adb shell pm list packages | grep -q "package:$pkg"; then
    echo -e "${RED}Package not found: $pkg${NC}"
    return 1
  fi

  # Confirm deletion (added for safety)
  read -r -p "This will delete ALL data and cache for $pkg (user 0). Confirm? (y/N): " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo -e "${GREEN}Operation canceled.${NC}"
    return 0
  fi

  # Clear data in user 0 context
  if adb shell pm clear --user 0 "$pkg" &>/dev/null; then
    echo -e "${GREEN}Data and cache deleted for $pkg (user 0).${NC}"
  else
    echo -e "${RED}Failed to clear data for $pkg (permission/user issue or command not supported)${NC}"
    # Fallback to clear cache only if full clear fails
    if adb shell "rm -rf /data/data/$pkg/cache/*" &>/dev/null; then
      echo -e "${YELLOW}Fallback: Only cache cleared for $pkg.${NC}"
    else
      echo -e "${RED}Failed to clear cache as fallback.${NC}"
      return 1
    fi
  fi
  read -r -p "Press Enter to return..."
}

