    echo -e "${RED}Invalid remote path.${NC}"
    return 1
  fi

  # Normalize /sdcard to /storage/emulated/0
  local resolved_src="$src"
  [[ "$resolved_src" == "/sdcard/"* ]] && resolved_src="/storage/emulated/0/${src#/sdcard/}"

  echo -e "${GREEN}Pulling $resolved_src -> $dst...${NC}"
  if ! timeout 300 adb pull "$resolved_src" "$dst"; then
    echo -e "${RED}Failed to pull $resolved_src${NC}"
