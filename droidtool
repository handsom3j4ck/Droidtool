# Delete file from device (requires ADB connection)
delete_file() {
  check_device_connection || return 1

  read -r -p "Remote file path to delete (e.g. /storage/emulated/0/Download/file.txt): " remote_path

  # Validate input
  if [[ -z "$remote_path" || ! "$remote_path" =~ ^/[a-zA-Z0-9_/.~-]+$ ]]; then
    echo -e "${RED}Invalid path provided.${NC}"
    return 1
  fi

  # Normalize path: replace /sdcard with /storage/emulated/0 for consistency
  local resolved_path="$remote_path"
  [[ "$resolved_path" == "/sdcard/"* ]] && resolved_path="/storage/emulated/0/${remote_path#/sdcard/}"

  local use_root=false
  local delete_desc="Deleting without root privileges"

  if is_rooted; then
    read -r -p "Device is rooted. Delete with root privileges? (y/n): " choice
    if [[ "$choice" == "y" || "$choice" == "Y" ]]; then
      use_root=true
      delete_desc="Deleting with root privileges"
    fi
  fi

  echo -e "${GREEN}$delete_desc${NC}"

  # Check if file exists
  local exists_cmd
  if $use_root; then
    exists_cmd="su -c \"test -f '$resolved_path' && echo exists\""
  else
    exists_cmd="test -f '$resolved_path' && echo exists"
  fi

  if ! adb shell "$exists_cmd" | grep -q "exists"; then
    if adb shell "test -d '$resolved_path'"; then
      echo -e "${RED}Path is a directory. Use delete folder option instead.${NC}"
    else
      echo -e "${RED}File does not exist: $resolved_path${NC}"
    fi
    return 1
  fi

  # Confirm deletion
  read -r -p "Are you sure you want to delete '$resolved_path'? (y/N): " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo -e "${GREEN}Deletion canceled.${NC}"
    return 0
  fi

  # Attempt deletion
  local delete_cmd
  if $use_root; then
    delete_cmd="su -c \"rm -f '$resolved_path' 2>/dev/null\""
  else
    delete_cmd="rm -f '$resolved_path' 2>/dev/null"
  fi

  if adb shell "$delete_cmd"; then
    echo -e "${GREEN}Successfully deleted: $resolved_path${NC}"
  else
    echo -e "${RED}Failed to delete: $resolved_path${NC}"
    return 1
  fi
  read -r -p "Press Enter to return..."
}

