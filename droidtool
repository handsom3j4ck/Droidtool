    echo -e "${YELLOW}Note: /sdcard is a symlink. Using /storage/emulated/0/ is more reliable.${NC}"
  fi

  local use_root=false
  if is_rooted; then
    read -r -p "Device is rooted. Use root privileges to push (allows restricted areas)? (y/n): " choice
