    local temp_path="/data/local/tmp/$(basename "$src")"
    if adb push "$src" "$temp_path" && adb shell su -c "cp \"$temp_path\" \"$dst\"" && adb shell su -c "rm \"$temp_path\""; then
      echo -e "${GREEN}Successfully pushed: $src (using root)${NC}"
    else
      echo -e "${RED}Failed to push $src using root${NC}"
      adb shell rm -f "$temp_path" &>/dev/null
      return 1
    fi
  else
    if ! timeout 300 adb push "$src" "$dst"; then
      echo -e "${RED}Failed to push $src${NC}"
      return 1
    fi
    echo -e "${GREEN}Successfully pushed: $src${NC}"
  fi
  read -r -p "Press Enter to return..."
}

