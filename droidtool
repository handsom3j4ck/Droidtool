disable_launcher() {
    # Detect if root is available
    root_available=false
    if adb shell "su -c 'id -u'" 2>/dev/null | grep -q '^0$'; then
        root_available=true
    fi
    
    # List of known TV launcher packages
    tv_launchers=("com.google.android.tvlauncher" "com.google.android.apps.tv.launcherx" "com.google.android.leanbacklauncher" "com.amazon.tv.launcher" "com.mitv.tvhome" "com.mitv.tvhome.atv") 
    
    # Check if any packages exist before proceeding
    packages_list=$(adb shell pm list packages --user 0 2>/dev/null || true)
    existing_packages=()
    for pkg in "${tv_launchers[@]}"; do
        exists=$(echo "$packages_list" | grep "^package:$pkg$" || true)
        if [ -n "$exists" ]; then
            existing_packages+=("$pkg")
        fi
    done
    if [ ${#existing_packages[@]} -eq 0 ]; then
        echo "TV launcher options not available for your device"
        read -p "Press enter to continue"
        return 0
    fi
    
    while true; do
        echo "Launcher Options:"
        echo "1) Enable"
        echo "2) Disable"
        echo "3) Exit"
        read -r -p "Enter your choice (1/2/3): " option
        
        case $option in
            1)
                use_root=false
                if $root_available; then
                    read -r -p "Do you want to use root privileges? (y/n): " root_choice
                    root_choice=$(echo "$root_choice" | tr '[:upper:]' '[:lower:]')
                    if [[ $root_choice == "y" ]]; then
                        use_root=true
                    elif [[ $root_choice == "n" ]]; then
                        use_root=false
                    else
                        echo "Invalid choice. Using non-root option."
                        use_root=false
                    fi
                else
                    echo "Root privileges not available. Using non-root option."
                fi
                for pkg in "${existing_packages[@]}"; do
                    if $use_root; then
                        adb shell su -c "pm enable $pkg"
                    else
                        adb shell pm enable --user 0 "$pkg"
                    fi
                done
                echo "TV Launcher(s) enabled."
                echo "Device needs a reboot. Press enter for reboot."
                read -p ""
                adb reboot
                exit 0
                ;;
            2)
                echo -e "${RED}Warning: This could damage your device. Use at your own risk.${NC}"
                read -r -p "Do you want to proceed? (y/n): " choice
                choice=$(echo "$choice" | tr '[:upper:]' '[:lower:]')
                if [[ $choice == "y" ]]; then
                    use_root=false
                    if $root_available; then
                        read -r -p "Do you want to use root privileges? (y/n): " root_choice
                        root_choice=$(echo "$root_choice" | tr '[:upper:]' '[:lower:]')
                        if [[ $root_choice == "y" ]]; then
                            use_root=true
                        elif [[ $root_choice == "n" ]]; then
                            use_root=false
                        else
                            echo "Invalid choice. Using non-root option."
                            use_root=false
                        fi
                    else
                        echo "Root privileges not available. Using non-root option."
                    fi
                    for pkg in "${existing_packages[@]}"; do
                        if $use_root; then
                            adb shell su -c "pm disable $pkg"
                        else
                            adb shell pm disable-user --user 0 "$pkg"
                        fi
                    done
                    echo "TV Launcher(s) disabled."
                    echo "Device needs a reboot. Press enter for reboot."
                    read -p ""
                    adb reboot
                    exit 0
                elif [[ $choice == "n" ]]; then
                    continue
                else
                    echo "Invalid choice. Returning to menu."
                    continue
                fi
                ;;
            3)
                return 0
                ;;
            *)
                echo "Invalid option. Please try again."
                ;;
        esac
    done
}

dns_settings() {
  check_device_connection || return 1
  while true; do
    echo -e "${GREEN}Set private DNS:${NC}"
    # Check current private DNS mode
    local current_mode=$(adb shell settings get global private_dns_mode 2>/dev/null | tr -d '\r')
    local current_specifier=$(adb shell settings get global private_dns_specifier 2>/dev/null | tr -d '\r')
    echo -e "${YELLOW}Current mode: ${current_mode:-off}${NC}"
    echo -e "${YELLOW}Current specifier: ${current_specifier:-None}${NC}"
    echo "1) Disable private DNS (default)"
    echo "2) Enable AdGuard private DNS (dns.adguard.com)"
    echo "3) Enable ControlD private DNS (p2.freedns.controld.com)"
    echo "4) Enable Quad9 private DNS (dns.quad9.net)"
    echo "5) Enable NextDNS private DNS (dns.nextdns.io - basic adblock)"
    echo "6) Enable Cloudflare private DNS (one.one.one.one)"
    echo "7) Back"
    read -r -p "Choose (1-7): " choice
    local success=false
    case $choice in
      1)
        if adb shell settings put global private_dns_mode off &>/dev/null && adb shell settings delete global private_dns_specifier &>/dev/null; then
          echo -e "${GREEN}Private DNS disabled.${NC}"
          success=true
        else
          echo -e "${RED}Failed to disable private DNS${NC}"
          success=false
        fi
        ;;
      2)
        if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier dns.adguard.com &>/dev/null; then
          echo -e "${GREEN}AdGuard private DNS enabled.${NC}"
          success=true
        else
          echo -e "${RED}Failed to enable AdGuard DNS${NC}"
          success=false
        fi
        ;;
      3)
        if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier p2.freedns.controld.com &>/dev/null; then
          echo -e "${GREEN}ControlD private DNS enabled.${NC}"
          success=true
        else
          echo -e "${RED}Failed to enable ControlD DNS${NC}"
          success=false
        fi
        ;;
      4)
        if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier dns.quad9.net &>/dev/null; then
          echo -e "${GREEN}Quad9 private DNS enabled.${NC}"
          success=true
        else
          echo -e "${RED}Failed to enable Quad9 DNS${NC}"
          success=false
        fi
        ;;
      5)
        if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier dns.nextdns.io &>/dev/null; then
          echo -e "${GREEN}NextDNS private DNS enabled (basic config). For custom, set up on nextdns.io.${NC}"
          success=true
        else
          echo -e "${RED}Failed to enable NextDNS${NC}"
          success=false
        fi
        ;;
      6)
        if adb shell settings put global private_dns_mode hostname &>/dev/null && adb shell settings put global private_dns_specifier one.one.one.one &>/dev/null; then
          echo -e "${GREEN}Cloudflare private DNS enabled.${NC}"
          success=true
        else
          echo -e "${RED}Failed to enable Cloudflare DNS${NC}"
          success=false
        fi
        ;;
      7)
        return 0
        ;;
      *)
        echo -e "${RED}Invalid choice.${NC}"
        ;;
    esac
    if $success; then
      read -r -p "Do you want to reboot the device? (y/n): " reboot_choice
      if [[ $reboot_choice =~ ^[Yy]$ ]]; then
        adb reboot &>/dev/null
        echo -e "${GREEN}Rebooting device...${NC}"
        return 0
      fi
      # If no, loop back to DNS settings menu
    else
      read -r -p "Press Enter to continue..."
    fi
  done
}

